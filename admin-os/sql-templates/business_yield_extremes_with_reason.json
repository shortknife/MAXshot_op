{
  "id": "business_yield_extremes_with_reason",
  "name": "Business Yield Extremes With Reason",
  "description": "Find highest and lowest APY day within a window and attach top rebalance reason per day.",
  "category": "business",
  "version": "1.0",
  "allowed_tables": [
    "market_metrics",
    "allocation_snapshots",
    "rebalance_decisions"
  ],
  "output_schema": {
    "highest_day": "date",
    "highest_avg_apy_pct": "numeric",
    "highest_top_reason": "text",
    "lowest_day": "date",
    "lowest_avg_apy_pct": "numeric",
    "lowest_top_reason": "text"
  },
  "slots": {
    "days": {
      "type": "number",
      "required": true
    },
    "date_from": {
      "type": "text",
      "required": false
    },
    "date_to": {
      "type": "text",
      "required": false
    },
    "timezone": {
      "type": "text",
      "required": true
    },
    "chain": {
      "type": "text",
      "required": false
    },
    "protocol": {
      "type": "text",
      "required": false
    },
    "vault_keyword": {
      "type": "text",
      "required": false
    }
  },
  "examples": [
    {
      "days": 7,
      "date_from": null,
      "date_to": null,
      "timezone": "Asia/Shanghai",
      "protocol": "Morpho",
      "vault_keyword": null
    }
  ]
}

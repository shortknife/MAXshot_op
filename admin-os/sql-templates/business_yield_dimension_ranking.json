{
  "id": "business_yield_dimension_ranking",
  "name": "Business Yield Dimension Ranking",
  "description": "Rank APY by chain or protocol within a recent time window.",
  "category": "business",
  "version": "1.0",
  "allowed_tables": [
    "market_metrics"
  ],
  "output_schema": {
    "dimension_value": "text",
    "avg_apy_pct": "numeric",
    "max_apy_pct": "numeric",
    "sample_count": "integer"
  },
  "slots": {
    "days": {
      "type": "number",
      "required": true
    },
    "date_from": {
      "type": "string",
      "required": false
    },
    "date_to": {
      "type": "string",
      "required": false
    },
    "dimension": {
      "type": "text",
      "required": true,
      "enum": [
        "chain",
        "protocol"
      ]
    },
    "limit": {
      "type": "number",
      "required": true
    },
    "chain": {
      "type": "string",
      "required": false
    },
    "protocol": {
      "type": "string",
      "required": false
    },
    "vault_keyword": {
      "type": "string",
      "required": false
    }
  },
  "examples": [
    {
      "days": 7,
      "date_from": null,
      "date_to": null,
      "dimension": "chain",
      "limit": 5,
      "protocol": "Morpho"
    },
    {
      "days": 7,
      "date_from": "2026-03-01",
      "date_to": "2026-03-31",
      "dimension": "protocol",
      "limit": 3,
      "chain": "arbitrum"
    }
  ]
}

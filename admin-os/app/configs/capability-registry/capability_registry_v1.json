  "capabilities": [
    {
      "capability_id": "capability.data_fact_query",
      "aliases": [
        "data_fact_query",
        "business_data_query"
      ],
      "name": "Business Data Query",
      "description": "Answer natural language questions over MAXshot business facts such as vaults, executions, APY, allocation, and rebalance outcomes.",
      "lifecycle": "active",
      "risk_class": "read_only",
      "examples": [
        "MAXshot 有哪些 vault 可以用？",
        "当前 vault APY 怎么样？",
        "给我最近一笔 execution 详情",
        "最近7天按链 APY 排名"
      ],
      "prompt_slot_schema": {
        "description": "Prompt-facing slots used by the capability matcher and clarification prompt.",
        "fields": [
          {
            "name": "scope",
            "type": "enum",
            "required": false,
            "values": [
              "yield",
              "vault",
              "execution",
              "rebalance",
              "allocation",
              "unknown"
            ]
          },
          {
            "name": "time_window",
            "type": "natural_language",
            "required": false,
            "examples": [
              "最近7天",
              "最近30天",
              "今天"
            ]
          },
          {
            "name": "aggregation",
            "type": "enum",
            "required": false,
            "values": [
              "avg",
              "max",
              "min",
              "realtime"
            ]
          },
          {
            "name": "vault_name",
            "type": "natural_language",
            "required": false
          },
          {
            "name": "chain",
            "type": "natural_language",
            "required": false
          },
          {
            "name": "protocol",
            "type": "natural_language",
            "required": false
          },
          {
            "name": "execution_id",
            "type": "string",
            "required": false
          },
          {
            "name": "dimension",
            "type": "enum",
            "required": false,
            "values": [
              "chain",
              "protocol",
              "vault"
            ]
          },
          {
            "name": "top_n",
            "type": "integer",
            "required": false,
            "minimum": 1,
            "maximum": 20
          }
        ]
      },
      "runtime_slot_schema": {
        "type": "object",
        "required": [
          "scope"
        ],
        "properties": {
          "scope": {
            "type": "string",
            "enum": [
              "yield",
              "vault",
              "execution",
              "rebalance",
              "allocation",
              "unknown"
            ]
          },
          "time_window_days": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1,
            "maximum": 365
          },
          "metric_agg": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "avg",
              "max",
              "min",
              "realtime",
              null
            ]
          },
          "vault_name": {
            "type": [
              "string",
              "null"
            ]
          },
          "chain": {
            "type": [
              "string",
              "null"
            ]
          },
          "protocol": {
            "type": [
              "string",
              "null"
            ]
          },
          "execution_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "dimension": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "chain",
              "protocol",
              "vault",
              null
            ]
          },
          "top_n": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1,
            "maximum": 20
          },
          "include_testnets": {
            "type": [
              "boolean",
              "null"
            ]
          }
        },
        "additionalProperties": true
      },
      "clarification_policy": {
        "max_turns": 2,
        "ui_mode": "natural_language_only",
        "allow_multi_match": true,
        "max_multi_match": 3,
        "ask_for": [
          "time_window",
          "aggregation",
          "vault_name",
          "chain",
          "protocol",
          "execution_id"
        ],
        "default_time_window_interpretation": "average_over_window",
        "default_aggregation": "avg",
        "prefer_examples_over_buttons": true
      },
      "tags": [
        "business_data",
        "data_query",
        "yield",
        "vault",
        "execution",
        "rebalance",
        "allocation",
        "sql"
      ]

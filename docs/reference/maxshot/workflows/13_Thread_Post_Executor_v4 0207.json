    {
      "parameters": {
        "jsCode": "// Save Current Item (锁死版：写 global，供下游节点读取)\nconst currentItem = $json || {};\nconst sd = $getWorkflowStaticData('global');\n\n// 存“完整快照”，并确保 index 存在\nsd.current_item = {\n  ...currentItem,\n  index: currentItem.index || currentItem.tweet_index || 0,\n};\n\nreturn { json: currentItem };\n"
      },

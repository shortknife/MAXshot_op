    {
      "parameters": {
        "jsCode": "// Handle Tweet Errors (锁死版：读 global.current_item，保证 source_id/notion_page_id 不丢)\nconst twitterResponse = $json || {};\nconst sd = $getWorkflowStaticData('global');\n\nconst originalItem = sd.current_item || {};\n\n// 兼容 Mock / 真 Twitter 输出\nconst tweetId = twitterResponse.tweet_id || twitterResponse.id || twitterResponse.data?.id || null;\n\n// 合并策略：originalItem 在前，twitterResponse 在后（不覆盖原字段就不会丢）\nconst result = {\n  ...originalItem,\n  ...twitterResponse,\n  published: !!tweetId,\n  tweet_id: tweetId,\n  id: tweetId,\n  error: tweetId ? null : (twitterResponse.error || \"Failed to get Tweet ID\"),\n};\n\nreturn { json: result };\n"
      },

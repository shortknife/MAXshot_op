    {
      "parameters": {
        "jsCode": "// Collect Thread Results (用输入汇总)\nconst staticData = $getWorkflowStaticData('global');\nconst allProcessedItems = $input.all();  // <-- 关键改这里\n\nconst successfulTweets = allProcessedItems.filter(item => item.json.published === true);\nconst firstItem = allProcessedItems[0]?.json || {};\nconst threadRootId = staticData.thread_root_id || successfulTweets[0]?.json?.tweet_id || null;\n\nlet sourceTable = null;\nlet timelineId = null;\ntry {\n  const triggerData = $items(\"Execute_Workflow_Trigger\")[0].json;\n  sourceTable = triggerData.source_table;\n  timelineId = triggerData.timeline_id || triggerData.id;\n} catch (e) {}\n\nreturn [{\n  json: {\n    thread_root_id: threadRootId,\n    source_table: sourceTable,\n    source_id: firstItem.source_id || firstItem.publication_id,\n    timeline_id: timelineId || firstItem.source_id,\n    notion_page_id: firstItem.notion_page_id,\n    status: successfulTweets.length > 0\n      ? (successfulTweets.length === allProcessedItems.length ? 'published' : 'partial')\n      : 'failed',\n    successful_count: successfulTweets.length,\n    total_count: allProcessedItems.length\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [

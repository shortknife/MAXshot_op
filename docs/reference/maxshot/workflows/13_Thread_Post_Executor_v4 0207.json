    {
      "parameters": {
        "jsCode": "// Set Reply To ID dynamically in the loop (deploy-ready)\n// 目的：给非首推注入 inReplyToStatusId（从 global staticData.last_tweet_id 读取）\n// 说明：这是旧版稳定方案，避免 Set 节点 Expression 读 staticData 的时序问题\n\nconst currentItem = $json || {};\nconst staticData = $getWorkflowStaticData('global');\n\nconst idx = currentItem.tweet_index ?? currentItem.index ?? 0;\n\n// 首推保护：不设置 inReplyToStatusId\nif (idx === 1 || currentItem.is_first === true) {\n  const outputItem = { ...currentItem };\n  delete outputItem.inReplyToStatusId;\n  return { json: outputItem };\n}\n\n// 读取上一条 tweet id\nlet lastTweetId = staticData.last_tweet_id || null;\n\n// fallback1：从 published_tweets 取最后一个\nif (!lastTweetId && Array.isArray(staticData.published_tweets) && staticData.published_tweets.length > 0) {\n  const last = staticData.published_tweets[staticData.published_tweets.length - 1];\n  lastTweetId = last?.tweet_id || null;\n}\n\n// fallback2：至少回复 thread_root_id\nif (!lastTweetId && staticData.thread_root_id) {\n  lastTweetId = staticData.thread_root_id;\n}\n\nif (!lastTweetId) {\n  throw new Error(\n    `No last_tweet_id found for tweet_index=${idx}. ` +\n    `thread_root_id=${staticData.thread_root_id || 'null'}, ` +\n    `published_tweets=${Array.isArray(staticData.published_tweets) ? staticData.published_tweets.length : 0}`\n  );\n}\n\nreturn {\n  json: {\n    ...currentItem,\n    inReplyToStatusId: String(lastTweetId),\n  },\n};\n"
      },

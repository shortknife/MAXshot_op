    {
      "parameters": {
        "jsCode": "// Prepare Thread Items (全兼容增强版)\nconst threadData = $json || {};\n\n// 1. 尝试多种可能的路径获取内容\nlet rawContent = threadData.thread_items || \n                 threadData.content || \n                 threadData.payload?.text || // 适配你当前的输入路径\n                 \"\";\n\nlet threadItems = [];\n\n// 2. 智能解析逻辑\nif (Array.isArray(rawContent)) {\n  // 如果本身就是数组，直接使用\n  threadItems = rawContent;\n} else if (typeof rawContent === 'string' && rawContent.length > 0) {\n  // 如果是字符串，尝试按分割线拆分 (适配目前的 payload.text 格式)\n  if (rawContent.includes('────────────────────')) {\n    threadItems = rawContent.split(/[\\s]*────────────────────[\\s]*/).filter(t => t.trim());\n  } else {\n    // 如果没有分割线，就当做单条推文处理\n    threadItems = [rawContent];\n  }\n}\n\n// 3. 提取元数据\nconst sourceId = threadData.id || threadData.source_id || threadData.publication_id;\nconst notionId = threadData.notion_page_id || threadData.payload?.source?.page_id || null;\nconst imageUrl = threadData.image_url || threadData.payload?.image_url || null;\n\n// 4. 映射输出\nreturn threadItems.map((item, idx) => {\n  const currentIndex = idx + 1;\n  // 提取文本内容 (适配对象格式或纯字符串格式)\n  const textContent = typeof item === 'object' ? (item.text || item.content) : item;\n\n  return {\n    json: {\n      text: textContent.trim(),\n      index: currentIndex,\n      tweet_index: currentIndex,\n      is_first: idx === 0,\n      is_last: idx === threadItems.length - 1,\n      total_count: threadItems.length,\n      publication_id: sourceId,\n      source_id: sourceId,\n      notion_page_id: notionId,\n      media_url: idx === 0 ? imageUrl : null, // 确保第一条带上图片地址\n      content_type: 'thread'\n    }\n  };\n});\n"
      },
      "id": "3e79018d-6a7e-4384-b09e-fa908cdd2086",
      "name": "Prepare Thread Items",

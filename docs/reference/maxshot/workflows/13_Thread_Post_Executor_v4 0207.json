      "parameters": {
        "jsCode": "// Update Reply ID (deploy-ready)\n// 目的：把上一条 tweet id 写入 global.last_tweet_id，供下一轮 Set ReplyID 读取\n\nconst sd = $getWorkflowStaticData('global');\n\nconst tweetId = $json.tweet_id || $json.id || $json.data?.id || null;\nif (tweetId) {\n  sd.last_tweet_id = String(tweetId);\n\n  // 记录 thread 根推（可选，但强烈建议保留，后续写表用）\n  if (($json.is_first === true) || ($json.tweet_index === 1) || ($json.index === 1)) {\n    sd.thread_root_id = String(tweetId);\n  }\n}\n\nreturn $json;\n"
